msgstr "Dinonaktifkan hingga %s"

#: plugins/trayicon
msgid "Disabled until restart"
msgstr "Dinonaktifkan hingga restart"

#: plugins/trayicon
msgid "Enable Safe Eyes"
msgstr "Aktifkan Safe Eyes"

#: plugins/trayicon
#, python-format
