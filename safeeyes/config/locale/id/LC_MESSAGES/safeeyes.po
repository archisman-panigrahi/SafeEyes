msgid_plural "For %(num)d Seconds"
msgstr[0] "Selama %(num)d Detik"

#: plugins/trayicon
#, python-format
msgid "Next break at %s"
msgstr "Istirahat berikutnya pukul %s"

#: plugins/trayicon
msgid "No Breaks Available"
msgstr "Tidak Ada Istirahat Tersedia"

#: plugins/trayicon
msgid "Settings"
msgstr "Pengaturan"

#: plugins/trayicon
msgid "Take a break now"
msgstr "Istirahat sekarang"

#: plugins/trayicon
msgid "Any break"
msgstr "Semua istirahat"

#: plugins/trayicon
msgid "Short break"
msgstr "Istirahat singkat"

#: plugins/trayicon
msgid "Long break"
msgstr "Istirahat panjang"

#: plugins/trayicon
msgid "Until restart"
msgstr "Hingga restart"

#: plugins/trayicon
msgid "Quit"
msgstr "Keluar"

# plugin/mediacontrol
msgid "Media Control"
msgstr "Kontrol Media"

# plugin/mediacontrol
msgid "Pause media players from the break screen"
msgstr "Jeda pemutar media dari layar istirahat"

# plugin/mediacontrol
msgid "Pause media"
msgstr "Jeda media"

# plugin/limitconsecutiveskipping
msgid "Limit Consecutive Skipping"
msgstr "Batasi Lewati Berturut-turut"

# plugin/limitconsecutiveskipping
msgid "How many skips or postpones are allowed in a row"
msgstr "Berapa banyak lewati atau tunda yang diizinkan secara berturut-turut"

# plugin/limitconsecutiveskipping
msgid "Limit how many breaks can be skipped or postponed in a row"
msgstr ""
"Batasi berapa banyak istirahat yang dapat dilewati atau ditunda secara "
"berturut-turut"

# plugin/limitconsecutiveskipping
#, python-format
msgid "Skipped or postponed %(num)d/%(allowed)d breaks in a row"
msgstr "Dilewati atau ditunda %(num)d/%(allowed)d istirahat berturut-turut"

# safeeyes/platform/io.github.slgobinath.SafeEyes.desktop
msgid "RSI Prevention"
msgstr "Pencegahan RSI"

msgid ""
"Please install service providing tray icons for your desktop environment."
msgstr ""
"Harap instal layanan yang menyediakan ikon tray untuk lingkungan desktop "
"Anda."

#, python-format
msgid "Next long break at %s"
msgstr "Istirahat panjang berikutnya pukul %s"

#, python-format
msgid "Next breaks at %(short)s/%(long)s"
msgstr "Istirahat berikutnya pukul %(short)s/%(long)s"

#, python-format
msgid "The required plugin '%s' is missing dependencies!"
msgstr "Plugin yang dibutuhkan '%s' memiliki dependensi yang hilang!"

msgid ""
"Please install the dependencies or disable the plugin. To hide this message, "
"you can also deactivate the plugin in the settings."
msgstr ""
"Harap instal dependensi atau nonaktifkan plugin. Untuk menyembunyikan pesan "
"ini, Anda juga dapat menonaktifkan plugin di pengaturan."

msgid "Click here for more information"
msgstr "Klik di sini untuk informasi lebih lanjut"

msgid "Disable plugin temporarily"
msgstr "Nonaktifkan plugin sementara"

msgid "Disable permanently"
msgstr "Nonaktifkan secara permanen"

msgid "License:"
msgstr "Lisensi:"

