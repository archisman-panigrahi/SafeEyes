# Short break
msgid "Gently close your eyes"
msgstr "Tutup mata Anda perlahan"

# Short break
msgid "Roll your eyes a few times to each side"
msgstr "Gerakkan mata Anda beberapa kali ke setiap sisi"

# Short break
msgid "Rotate your eyes in clockwise direction"
msgstr "Putar mata Anda searah jarum jam"

# Short break
msgid "Rotate your eyes in counterclockwise direction"
msgstr "Putar mata Anda berlawanan arah jarum jam"

# Short break
msgid "Blink your eyes"
msgstr "Kedipkan mata Anda"

# Short break
msgid "Focus on a point in the far distance"
msgstr "Fokus pada suatu titik di kejauhan"

# Short break
msgid "Have some water"
msgstr "Minum air putih"

# Long break
msgid "Walk for a while"
msgstr "Berjalan sebentar"

# Long break
msgid "Lean back at your seat and relax"
msgstr "Bersandarlah di kursi Anda dan bersantailah"

# Commandline arg description
msgid "show the about dialog"
msgstr "tampilkan dialog tentang"

# Commandline arg description
msgid "disable the currently running Safe Eyes instance"
msgstr "nonaktifkan instans Safe Eyes yang sedang berjalan"

# Commandline arg description
msgid "enable the currently running Safe Eyes instance"
msgstr "aktifkan instans Safe Eyes yang sedang berjalan"

# Commandline arg description
msgid "quit the running Safe Eyes instance and exit"
msgstr "keluar dari instans Safe Eyes yang berjalan dan tutup"

# Commandline arg description
msgid "show the settings dialog"
msgstr "tampilkan dialog pengaturan"

# Commandline arg description
msgid "start Safe Eyes in debug mode"
msgstr "jalankan Safe Eyes dalam mode debug"

# Commandline arg description
msgid "print the status of running Safe Eyes instance and exit"
msgstr "cetak status instans Safe Eyes yang berjalan lalu keluar"

# Status message
msgid "Safe Eyes is not running"
msgstr "Safe Eyes tidak berjalan"

# About dialog
msgid "Close"
msgstr "Tutup"

# Description in about dialog
# Safe Eyes protects your eyes from eye strain (asthenopia) by reminding you to take breaks while you're working long hours at the computer
msgid ""
"Safe Eyes protects your eyes from eye strain (asthenopia) by reminding you "
"to take breaks while you're working long hours at the computer"
msgstr ""
"Safe Eyes melindungi mata Anda dari kelelahan mata (astenopia) dengan "
"mengingatkan Anda untuk beristirahat saat bekerja lama di depan komputer"

# About dialog
msgid "License"
msgstr "Lisensi"

# About dialog
msgid "List of Contributors"
msgstr "Daftar Kontributor"

# About dialog
msgid "Help us translate this app"
msgstr "Bantu kami menerjemahkan aplikasi ini"

# Break screen
msgid "Skip"
msgstr "Lewati"

# Break screen
msgid "Postpone"
msgstr "Tunda"

# Settings dialog
msgid "Break duration (in seconds)"
msgstr "Durasi istirahat (dalam detik)"

# Settings dialog
msgid "Interval between two breaks (in minutes)"
msgstr "Interval antara dua istirahat (dalam menit)"

# Settings dialog
msgid "Time to prepare for a break (in seconds)"
msgstr "Waktu persiapan sebelum istirahat (dalam detik)"

# Settings dialog
msgid "Postponement duration (in minutes)"
msgstr "Durasi penundaan (dalam menit)"

# Settings dialog
msgid "Show breaks in random order"
msgstr "Tampilkan istirahat dalam urutan acak"

# Settings dialog
msgid "Strict break (No way to skip breaks)"
msgstr "Istirahat ketat (Tidak ada cara untuk melewati istirahat)"

# Settings dialog
msgid "Allow postponing breaks"
msgstr "Izinkan penundaan istirahat"

# Settings dialog
msgid "Persist the internal state"
msgstr "Pertahankan status internal"

# Settings dialog
msgid "Long break interval must be a multiple of short break interval"
msgstr ""
"Interval istirahat panjang harus merupakan kelipatan dari interval istirahat "
"singkat"

# Settings dialog
msgid "Reset"
msgstr "Atur Ulang"

# Settings dialog
msgid "Are you sure you want to reset all settings to default?"
msgstr "Apakah Anda yakin ingin mengatur ulang semua pengaturan ke default?"

# Settings dialog
msgid "Options"
msgstr "Opsi"

# Settings dialog
msgid "Short Breaks"
msgstr "Istirahat Singkat"

# Settings dialog
msgid "Long Breaks"
msgstr "Istirahat Panjang"

# Settings dialog
msgid "Delete"
msgstr "Hapus"

# Settings dialog
msgid "Are you sure you want to delete this break?"
msgstr "Apakah Anda yakin ingin menghapus istirahat ini?"

# Settings dialog
msgid "You can't undo this action."
msgstr "Anda tidak dapat membatalkan tindakan ini."

# Settings dialog
msgid "Break"
msgstr "Istirahat"

# Settings dialog
msgid "Breaks"
msgstr "Istirahat"

# Settings dialog
msgid "Plugins"
msgstr "Plugin"

# Settings dialog
msgid "Type"
msgstr "Tipe"

# Settings dialog
msgid "Short"
msgstr "Singkat"

# Settings dialog
msgid "Long"
msgstr "Panjang"

# Settings dialog
msgid "Image"
msgstr "Gambar"

# Settings dialog
msgid "Select"
msgstr "Pilih"

# Settings dialog
msgid "Please select an image"
msgstr "Silakan pilih gambar"

# Settings dialog
msgid "Duration"
msgstr "Durasi"

# Settings dialog
msgid "Time to wait"
msgstr "Waktu tunggu"

# Settings dialog
msgid "Override"
msgstr "Timpa"

# Settings dialog
msgid "Time (in seconds)"
msgstr "Waktu (dalam detik)"

# Settings dialog
msgid "Time (in minutes)"
msgstr "Waktu (dalam menit)"

# Settings dialog
msgid "Break Settings"
msgstr "Pengaturan Istirahat"

# Settings dialog
msgid "Plugin Settings"
msgstr "Pengaturan Plugin"

# Settings dialog
#, python-format
msgid "Plugin does not support %s desktop environment"
msgstr "Plugin tidak mendukung lingkungan desktop %s"

# Settings dialog
#, python-format
msgid "Please install the Python module '%s'"
msgstr "Harap instal modul Python '%s'"

# Settings dialog
#, python-format
msgid "Please install the command-line tool '%s'"
msgstr "Harap instal alat baris perintah '%s'"

# Settings dialog
msgid "Invalid cron expression '%s'"
msgstr "Ekspresi cron tidak valid '%s'"

# Settings dialog
#, python-format
msgid "Please add the resource %(resource)s to %(config_resource)s directory"
msgstr ""
"Harap tambahkan sumber daya %(resource)s ke direktori %(config_resource)s"

# Settings dialog
msgid "New Break"
msgstr "Istirahat Baru"

# Settings dialog
msgid "Remove"
msgstr "Hapus"

# Settings dialog
msgid "Discard"
msgstr "Buang"

# Settings dialog
msgid "Save"
msgstr "Simpan"

# plugin/audiblealert
msgid "Audible Alert"
msgstr "Peringatan Suara"

# plugin/audiblealert
msgid "Play audible alert before and after breaks"
msgstr "Putar peringatan suara sebelum dan sesudah istirahat"

# plugin/audiblealert
msgid "Play audible alert before breaks"
msgstr "Putar peringatan suara sebelum istirahat"

# plugin/audiblealert
msgid "Play audible alert after breaks"
msgstr "Putar peringatan suara setelah istirahat"

# plugin/donotdisturb
msgid "Do Not Disturb"
msgstr "Jangan Ganggu"

# plugin/donotdisturb
msgid "Skip break if the active window is in fullscreen mode"
msgstr "Lewati istirahat jika jendela aktif dalam mode layar penuh"

# plugin/donotdisturb
msgid "Do not interrupt these windows anytime"
msgstr "Jangan ganggu jendela-jendela ini kapan pun"

# plugin/donotdisturb
msgid "Interrupt these windows regardless of their state"
msgstr "Ganggu jendela-jendela ini terlepas dari statusnya"

# plugin/donotdisturb
msgid "Switch the interruptible windows to normal mode"
msgstr "Alihkan jendela yang dapat diganggu ke mode normal"

# plugin/donotdisturb
msgid "Do not disturb while on battery"
msgstr "Jangan ganggu saat menggunakan baterai"

# plugin/healthstats
msgid "Health Statistics"
msgstr "Statistik Kesehatan"

# plugin/healthstats
msgid "Show statistics based on how you use Safe Eyes"
msgstr "Tampilkan statistik berdasarkan cara Anda menggunakan Safe Eyes"

# plugin/healthstats
msgid "Statistics reset interval (cron expression)"
msgstr "Interval pengaturan ulang statistik (ekspresi cron)"

# plugin/notification
msgid "Notification"
msgstr "Notifikasi"

# plugin/notification
msgid "Show a system notification before breaks"
msgstr "Tampilkan notifikasi sistem sebelum istirahat"

# plugin/notification
#, python-format
msgid "Ready for a short break in %s seconds"
msgstr "Siap untuk istirahat singkat dalam %s detik"

# plugin/notification
#, python-format
msgid "Ready for a long break in %s seconds"
msgstr "Siap untuk istirahat panjang dalam %s detik"

# plugin/screensaver
msgid "Screensaver"
msgstr "Screensaver"

# plugin/screensaver
msgid "Lock the screen after long breaks by starting screensaver/screen-lock"
msgstr ""
"Kunci layar setelah istirahat panjang dengan memulai screensaver/kunci layar"

# plugin/screensaver
msgid "Custom screensaver or screen-lock command"
msgstr "Perintah screensaver atau kunci layar kustom"

# plugin/screensaver
msgid "Minimum seconds to skip without screensaver"
msgstr "Minimum detik untuk melewati tanpa screensaver"

# plugin/screensaver
msgid "Lock screen"
msgstr "Kunci layar"

# plugin/smartpause
msgid "Smart Pause"
msgstr "Jeda Cerdas"

# plugin/smartpause
msgid "Pause Safe Eyes if the system is idle"
msgstr "Jeda Safe Eyes jika sistem tidak aktif"

# plugin/smartpause
msgid "Minimum idle time to pause Safe Eyes (in seconds)"
msgstr "Waktu tidak aktif minimum untuk menjeda Safe Eyes (dalam detik)"

# plugin/smartpause
msgid "Interpret idle time equivalent to upcoming break duration as a break"
msgstr ""
"Tafsirkan waktu tidak aktif yang setara dengan durasi istirahat mendatang "
"sebagai istirahat"

# plugin/smartpause
msgid "Postpone the next break until the system becomes idle"
msgstr "Tunda istirahat berikutnya hingga sistem menjadi tidak aktif"

#: plugins/trayicon
msgid "Tray Icon"
msgstr "Ikon Tray"

#: plugins/trayicon
msgid "Show a tray icon in the notification area"
msgstr "Tampilkan ikon tray di area notifikasi"

#: plugins/trayicon
msgid "Show next break time in tray icon"
msgstr "Tampilkan waktu istirahat berikutnya di ikon tray"

#: plugins/trayicon
msgid "Allow disabling Safe Eyes"
msgstr "Izinkan penonaktifan Safe Eyes"

#: plugins/trayicon
msgid "About"
msgstr "Tentang"

#: plugins/trayicon
msgid "Disable Safe Eyes"
msgstr "Nonaktifkan Safe Eyes"

#: plugins/trayicon
#, python-format
